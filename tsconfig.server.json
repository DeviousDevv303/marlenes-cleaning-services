{
  "include": [
    "drizzle/**/*",
    "server/index.ts",
    "server/auth.ts",
    "server/db.ts",
    "server/email.ts",
    "server/seed.ts",
    "server/validation.ts",
    "server/routes/**/*"
  ],
  "exclude": ["node_modules", "build", "dist", "**/*.test.ts"],
  "compilerOptions": {
    "noEmit": true,
    "module": "ESNext",
    "target": "ES2022",
    "strict": true,
    "lib": ["esnext"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "types": ["node"]
  }
}
